<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>TAJRENT - Rental Marketplace</title>
  <style>
    :root{--bg:#f5f7ff;--card:#fff;--line:#dce5f4;--text:#10233f;--muted:#5e6f8a;--brand:#1f64ff;--brand-2:#7b5dff;--ok:#15b97a}
    *{box-sizing:border-box}body{margin:0;font-family:Inter,system-ui,sans-serif;background:var(--bg);color:var(--text)}
    .top{position:sticky;top:0;background:linear-gradient(90deg,#ffffff,#f4f8ff);border-bottom:1px solid var(--line);padding:10px 14px;display:flex;gap:10px;justify-content:space-between;z-index:5}
    .brand{font-weight:800}.tag{font-size:12px;background:#eaf0ff;color:var(--brand);padding:2px 8px;border-radius:999px}
    .row{display:grid;gap:12px;max-width:1280px;margin:12px auto;padding:0 12px;grid-template-columns:280px 1fr}
    .card{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:12px;box-shadow:0 8px 24px rgba(16,35,63,.05)}
    .btn{border:1px solid var(--line);background:#fff;border-radius:8px;padding:7px 10px;cursor:pointer;font-weight:600}
    .btn.primary,.role.active{background:linear-gradient(135deg,var(--brand),var(--brand-2));color:#fff;border-color:transparent}
    .roles{display:flex;gap:6px;flex-wrap:wrap}.role{border:1px solid var(--line);background:#fff;border-radius:8px;padding:7px 9px;cursor:pointer}
    .g{display:grid;gap:8px}.g2{grid-template-columns:repeat(2,minmax(0,1fr))}
    input,select,textarea{width:100%;border:1px solid var(--line);border-radius:8px;padding:7px;margin-top:3px}
    label{font-size:12px;color:var(--muted);font-weight:600}textarea{min-height:70px}
    .items{display:grid;gap:10px;grid-template-columns:repeat(auto-fill,minmax(260px,1fr))}
    .item{border:1px solid var(--line);border-radius:10px;overflow:hidden;background:#fff}
    .item img{width:100%;height:165px;object-fit:cover;background:#dfe7f5}.p{padding:10px}
    .chips{display:flex;gap:6px;flex-wrap:wrap}.chip{font-size:12px;background:#eff4ff;color:#2f4d84;padding:3px 8px;border-radius:999px}
    .muted{color:var(--muted);font-size:13px}.actions{display:flex;gap:7px;flex-wrap:wrap;margin-top:8px}
    .split{display:grid;gap:12px;grid-template-columns:1.2fr .8fr}.hidden{display:none!important}
    .k{border:1px solid var(--line);border-radius:10px;padding:8px;background:#fbfdff}
    .v{font-size:20px;font-weight:800}.thumbs{display:grid;gap:5px}
    .media{display:grid;gap:8px;grid-template-columns:1fr 110px}.media img,.media video{width:100%;max-height:260px;object-fit:cover;border-radius:8px;border:1px solid var(--line)}
    .hero{max-width:1280px;margin:12px auto 0;padding:0 12px}
    .heroBox{border-radius:14px;background:linear-gradient(135deg,#1f64ff,#7b5dff);color:#fff;padding:14px;display:flex;justify-content:space-between;align-items:center;gap:12px}
    .heroIcons{display:flex;gap:10px;flex-wrap:wrap}
    .animIcon{display:inline-flex;align-items:center;justify-content:center;width:34px;height:34px;border-radius:10px;background:rgba(255,255,255,.2);font-size:18px;animation:float 2s ease-in-out infinite}
    .animIcon:nth-child(2){animation-delay:.2s}.animIcon:nth-child(3){animation-delay:.4s}.animIcon:nth-child(4){animation-delay:.6s}
    .supportRow{display:flex;gap:8px;align-items:flex-end}
    .supportRow textarea{margin-top:0;min-height:60px}
    .status{display:inline-block;padding:2px 8px;border-radius:999px;font-size:12px;background:#eafaf3;color:#0b8e5b}
    @keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-5px)}}
    @media (max-width:1024px){.row{grid-template-columns:1fr}.split{grid-template-columns:1fr}}
  </style>
</head>
<body>
<header class="top">
  <div class="brand">TAJRENT <span class="tag">Customer • Owner • Admin</span></div>
  <nav class="roles">
    <button class="role active" data-role="guest">Guest</button>
    <button class="role" data-role="customer">Customer</button>
    <button class="role" data-role="owner">Owner</button>
    <button class="role" data-role="admin">Admin</button>
  </nav>
</header>

<section class="hero">
  <div class="heroBox">
    <div>
      <strong>New UX update</strong>
      <div style="font-size:13px;opacity:.95">Fast chats, improved design, and animated icons are already in the demo.</div>
    </div>
    <div class="heroIcons" aria-label="animated icons">
      <span class="animIcon">🛍️</span>
      <span class="animIcon">💬</span>
      <span class="animIcon">🚚</span>
      <span class="animIcon">⭐</span>
    </div>
  </div>
</section>

<main class="row">
  <aside class="card" id="filters">
    <h3 style="margin:0 0 8px">Search & Filters</h3>
    <div class="g g2">
      <label>Query<input id="q" placeholder="name, tags, owner"></label>
      <label>Category<select id="fCategory"></select></label>
      <label>Subcategory<select id="fSubcategory"></select></label>
      <label>Tag<select id="fTag"></select></label>
      <label>City<select id="fCity"></select></label>
      <label>District<select id="fDistrict"></select></label>
      <label>Rental type<select id="fRentalType"></select></label>
      <label>Condition<select id="fCondition"></select></label>
      <label>Delivery<select id="fDelivery"></select></label>
      <label>Date<input id="fDate" type="date"></label>
      <label>Price max<input id="fPrice" type="number"></label>
      <label>Distance max (km)<input id="fDistance" type="number"></label>
      <label>Rating min<select id="fRating"></select></label>
      <label>Deposit max<input id="fDeposit" type="number"></label>
      <label>Sort<select id="fSort"></select></label>
    </div>
    <div class="actions">
      <button class="btn primary" id="apply">Apply</button>
      <button class="btn" id="reset">Reset</button>
    </div>
    <p id="count" class="muted"></p>
    <h4 style="margin:8px 0 4px">Architecture Overview</h4>
    <ul class="muted">
      <li>Role-based UX: Guest/Customer/Owner/Admin</li>
      <li>Domain: users, categories, tags, items, media, bookings, reviews, likes, follows, chat, notifications, moderation</li>
      <li>Customer marketplace + booking + detail + profile</li>
      <li>Owner studio: inventory, pricing, calendar, booking queue, income</li>
      <li>Admin panel: users/items/complaints/bans/analytics/revenue + monetization hooks</li>
    </ul>
  </aside>

  <section class="g">
    <section class="card" id="customerPane">
      <h3 style="margin:0 0 8px">TAJRENT Customer</h3>
      <div id="items" class="items"></div>
    </section>

    <section class="card" id="detailPane">
      <h3 style="margin:0 0 8px">Item Detail</h3>
      <div id="detail"></div>
    </section>

    <section class="card" id="profilePane">
      <h3 style="margin:0 0 8px">Profile</h3>
      <div id="profile"></div>
    </section>

    <section class="card hidden" id="ownerPane">
      <h3 style="margin:0 0 8px">TAJRENT Owner</h3>
      <div id="owner"></div>
    </section>

    <section class="card hidden" id="adminPane">
      <h3 style="margin:0 0 8px">Admin & Moderation</h3>
      <div id="admin"></div>
    </section>

    <section class="card" id="chatPane">
      <h3 style="margin:0 0 8px">Chat & Notifications</h3>
      <div class="split">
        <div>
          <div id="chat"></div>
          <div class="actions">
            <button class="btn quick" data-text="Hello, can I pick up at 10:00?">Quick pickup</button>
            <button class="btn quick" data-text="Please upload a current item video and close-up condition photos before I place a booking.">Quick video ask</button>
            <button class="btn quick" data-text="Auto: booking confirmed + return reminder.">Quick auto message</button>
          </div>
        </div>
        <div>
          <div id="notifications"></div>
        </div>
      </div>
    </section>

    <section class="card" id="supportPane">
      <h3 style="margin:0 0 8px">Contact Us <span class="status">online</span></h3>
      <div id="supportChat"></div>
      <div class="actions">
        <button class="btn supportQuick" data-text="Hello! I want to know how deposit refund works.">Deposit</button>
        <button class="btn supportQuick" data-text="Hello! I need help with booking cancellation.">Cancellation</button>
        <button class="btn supportQuick" data-text="Hello! I have a question about account verification.">Verification</button>
      </div>
      <div class="supportRow">
        <label style="flex:1">Message
          <textarea id="supportInput" placeholder="Write your question..."></textarea>
        </label>
        <button class="btn primary" id="supportSend">Send</button>
      </div>
    </section>
  </section>
</main>

<script>
  const state={
    role:'guest',selectedItem:1,selectedMedia:0,selectedProfile:2,
    categories:[
      {id:'tools',sub:['Power Tools','Hand Tools','Safety']},
      {id:'events',sub:['Audio/Video','Decor','Furniture']},
      {id:'baby',sub:['Strollers','Furniture','Toys']},
      {id:'sports',sub:['Cycling','Camping','Fitness']},
      {id:'electronics',sub:['Cameras','Computers','Projectors']}
    ],
    tags:['urgent-rental','verified-owner','delivery-available','top-rated','insured','business-plan'],
    users:[
      {id:1,role:'customer',name:'Nasim Rahmon',city:'Dushanbe',bio:'Weekend DIY renter.',rating:4.8,rentalCount:43,reviewCount:31,verified:true,followers:15,following:9,twoFa:true},
      {id:2,role:'owner',name:'Soro Rentals',city:'Khujand',bio:'Professional rentals.',rating:4.9,rentalCount:311,reviewCount:204,verified:true,followers:144,following:26,twoFa:true}
    ],
    items:[
      {id:1,name:'Bosch Hammer Drill Set',category:'tools',subcategory:'Power Tools',tags:['verified-owner','delivery-available','insured'],city:'Dushanbe',district:'Sino',distance:2.4,pricing:{hourly:3,daily:12,weekly:60,monthly:180,deposit:70},rating:4.8,condition:'Excellent',delivery:'Yes',popularity:420,likes:124,views:2200,ownerId:2,rentalType:'daily',rules:['ID required','Return cleaned'],features:['SDS-plus','Carry case','Battery'],availability:['2026-04-18','2026-04-19','2026-04-21'],media:[{type:'image',url:'https://images.unsplash.com/photo-1504148455328-c376907d081c?auto=format&fit=crop&w=1200&q=80'},{type:'image',url:'https://images.unsplash.com/photo-1617575521317-d2974f3b56d2?auto=format&fit=crop&w=1200&q=80'},{type:'video',url:'https://interactive-examples.mdn.mozilla.net/media/cc0-videos/flower.mp4'}]},
      {id:2,name:'4K Projector for Events',category:'events',subcategory:'Audio/Video',tags:['top-rated','business-plan','delivery-available'],city:'Khujand',district:'Gafurov',distance:8,pricing:{hourly:5,daily:30,weekly:160,monthly:480,deposit:120},rating:4.9,condition:'Like New',delivery:'Yes',popularity:530,likes:203,views:3404,ownerId:2,rentalType:'hourly',rules:['Indoor use preferred'],features:['4K','HDMI + USB','Wireless'],availability:['2026-04-19','2026-04-20','2026-04-24'],media:[{type:'image',url:'https://images.unsplash.com/photo-1535016120720-40c646be5580?auto=format&fit=crop&w=1200&q=80'},{type:'image',url:'https://images.unsplash.com/photo-1527443154391-507e9dc6c5cc?auto=format&fit=crop&w=1200&q=80'},{type:'video',url:'https://interactive-examples.mdn.mozilla.net/media/cc0-videos/flower.mp4'}]},
      {id:3,name:'Baby Stroller Premium',category:'baby',subcategory:'Strollers',tags:['urgent-rental','verified-owner'],city:'Dushanbe',district:'Firdavsi',distance:3.2,pricing:{hourly:2,daily:9,weekly:44,monthly:120,deposit:40},rating:4.6,condition:'Good',delivery:'No',popularity:160,likes:88,views:1040,ownerId:2,rentalType:'weekly',rules:['Return dry'],features:['Foldable','Rain cover'],availability:['2026-04-18','2026-04-23'],media:[{type:'image',url:'https://images.unsplash.com/photo-1607453998774-d533f65dac99?auto=format&fit=crop&w=1200&q=80'},{type:'image',url:'https://images.unsplash.com/photo-1522771930-78848d9293e8?auto=format&fit=crop&w=1200&q=80'}]}
    ],
    reviews:[{itemId:1,user:'Amina',rating:5,text:'Perfect condition.'},{itemId:1,user:'Farid',rating:4,text:'Battery lasted all day.'},{itemId:2,user:'Shoh',rating:5,text:'Projection quality amazing.'}],
    bookings:[{id:5001,itemId:1,customerId:1,ownerId:2,start:'2026-04-18',end:'2026-04-20',rentalType:'daily',status:'requested',lateFee:8,deposit:'held'},{id:5002,itemId:2,customerId:1,ownerId:2,start:'2026-04-24',end:'2026-04-24',rentalType:'hourly',status:'confirmed',lateFee:15,deposit:'held'}],
    likes:{items:new Set([1]),owners:new Set([2])},follows:{owners:new Set([2]),categories:new Set(['tools'])},
    notifications:[{type:'booking',text:'Booking #5002 confirmed',ts:'10m ago'},{type:'message',text:'Owner sent inspection video',ts:'22m ago'},{type:'follower',text:'2 new owners in followed category',ts:'1h ago'}],
    chat:[{from:'Owner',text:'Hello! Item is available and moderated.'},{from:'Customer',text:'Can I rent from 18th morning?'},{from:'Owner',text:'Yes, submit booking request.'}],
    supportChat:[{from:'Support',text:'Hello! We are online. How can we help you?'},{from:'Customer',text:'I want to know how to check my booking status.'},{from:'Support',text:'Open your profile and the Rental history block — current statuses are shown there.'}],
    complaints:[{id:91,subject:'Late return dispute',status:'Open',severity:'Medium'},{id:92,subject:'Photo mismatch report',status:'In Review',severity:'High'}],
    monetization:{commission:8,promoted:15,ownerSub:29,premium:49,insurance:3}
  };
  const $=id=>document.getElementById(id);
  const owner=item=>state.users.find(u=>u.id===item.ownerId)||null;
  const addOptions=(id,arr,label='All')=>{const s=$(id);s.innerHTML='';s.insertAdjacentHTML('beforeend',`<option value="">${label}</option>`);arr.forEach(v=>s.insertAdjacentHTML('beforeend',`<option value="${v}">${v}</option>`));};
  function initFilters(){
    addOptions('fCategory',state.categories.map(c=>c.id));addOptions('fSubcategory',[...new Set(state.categories.flatMap(c=>c.sub))]);addOptions('fTag',state.tags);
    addOptions('fCity',[...new Set(state.items.map(i=>i.city))]);addOptions('fDistrict',[...new Set(state.items.map(i=>i.district))]);addOptions('fRentalType',['hourly','daily','weekly','monthly']);
    addOptions('fCondition',[...new Set(state.items.map(i=>i.condition))]);addOptions('fDelivery',['Yes','No']);addOptions('fRating',['4.0','4.5','4.8']);addOptions('fSort',['relevance','price-asc','price-desc','rating-desc','distance-asc','popularity-desc'],'Relevance');
  }
  function currentFilters(){return{
    q:$('q').value.trim().toLowerCase(),category:$('fCategory').value,subcategory:$('fSubcategory').value,tag:$('fTag').value,city:$('fCity').value,district:$('fDistrict').value,rentalType:$('fRentalType').value,condition:$('fCondition').value,delivery:$('fDelivery').value,date:$('fDate').value,price:+($('fPrice').value||0),distance:+($('fDistance').value||0),rating:+($('fRating').value||0),deposit:+($('fDeposit').value||0),sort:$('fSort').value};}
  function filterItems(){
    const f=currentFilters();
    let x=state.items.filter(i=>{
      const searchText=[i.name,i.category,i.subcategory,i.tags.join(' '),owner(i)?.name||''].join(' ').toLowerCase();
      return (!f.q||searchText.includes(f.q))&&(!f.category||i.category===f.category)&&(!f.subcategory||i.subcategory===f.subcategory)&&(!f.tag||i.tags.includes(f.tag))&&(!f.city||i.city===f.city)&&(!f.district||i.district===f.district)&&(!f.rentalType||i.rentalType===f.rentalType)&&(!f.condition||i.condition===f.condition)&&(!f.delivery||i.delivery===f.delivery)&&(!f.date||i.availability.includes(f.date))&&(!f.price||i.pricing.daily<=f.price)&&(!f.distance||i.distance<=f.distance)&&(!f.rating||i.rating>=f.rating)&&(!f.deposit||i.pricing.deposit<=f.deposit);
    });
    const s={'price-asc':(a,b)=>a.pricing.daily-b.pricing.daily,'price-desc':(a,b)=>b.pricing.daily-a.pricing.daily,'rating-desc':(a,b)=>b.rating-a.rating,'distance-asc':(a,b)=>a.distance-b.distance,'popularity-desc':(a,b)=>b.popularity-a.popularity};if(s[f.sort])x.sort(s[f.sort]);
    renderItems(x);$('count').textContent=`${x.length} items found`;if(x.length&&!x.some(i=>i.id===state.selectedItem))state.selectedItem=x[0].id;renderDetail();
  }
  function renderItems(items){$('items').innerHTML=items.map(i=>`<article class="item"><img src="${i.media.find(m=>m.type==='image')?.url||''}" alt="${i.name}"><div class="p"><strong>${i.name}</strong><div class="muted">${i.city}, ${i.district} • ${i.distance} km • ${i.condition}</div><div class="muted">$${i.pricing.hourly}/h • $${i.pricing.daily}/d • deposit $${i.pricing.deposit}</div><div class="chips">${i.tags.map(t=>`<span class="chip">${t}</span>`).join('')}</div><div class="chips" style="margin-top:6px"><span class="chip">⭐ ${i.rating}</span><span class="chip">❤ ${i.likes}</span><span class="chip">👁 ${i.views}</span><span class="chip">${owner(i)?.name||''}</span></div><div class="actions"><button class="btn primary" onclick="selectItem(${i.id})">View</button><button class="btn" onclick="toggleItemLike(${i.id})">${state.likes.items.has(i.id)?'Unlike':'Like'}</button><button class="btn" onclick="addFavorite(${i.id})">Favorite</button></div></div></article>`).join('');}
  function renderDetail(){
    const i=state.items.find(x=>x.id===state.selectedItem)||state.items[0];if(!i)return;const o=owner(i),m=i.media[state.selectedMedia]||i.media[0];
    const reviews=state.reviews.filter(r=>r.itemId===i.id),similar=state.items.filter(x=>x.id!==i.id&&x.category===i.category).slice(0,2),sameOwner=state.items.filter(x=>x.id!==i.id&&x.ownerId===i.ownerId).slice(0,2);
    const main=m?.type==='video'?`<video controls src="${m.url}"></video>`:`<img src="${m?.url||''}" alt="${i.name}">`;
    $('detail').innerHTML=`<div class="split"><div><h4 style="margin:0">${i.name}</h4><div class="muted">${i.category} / ${i.subcategory} • ${i.city}, ${i.district}</div><div class="media" style="margin-top:8px"><div>${main}</div><div class="thumbs">${i.media.map((x,n)=>`<button class="btn" onclick="selectMedia(${n})">${x.type==='video'?'▶ Video':`<img src='${x.url}' alt='thumb'>`}</button>`).join('')}</div></div><h4>Features</h4><div class="chips">${i.features.map(f=>`<span class="chip">${f}</span>`).join('')}</div><h4>Rules</h4><ul>${i.rules.map(r=>`<li>${r}</li>`).join('')}</ul><h4>Availability</h4><div class="chips">${i.availability.map(d=>`<span class="chip">${d}</span>`).join('')}</div><h4>Reviews (${reviews.length})</h4>${reviews.map(r=>`<p class="muted">⭐ ${r.rating} <b>${r.user}</b>: ${r.text}</p>`).join('')||'<p class="muted">No reviews yet.</p>'}</div><div><div class="k"><div class="muted">Rating</div><div class="v">${i.rating}</div></div><div class="k" style="margin-top:8px"><div class="muted">Views</div><div class="v">${i.views}</div></div><div class="k" style="margin-top:8px"><div class="muted">Likes</div><div class="v">${i.likes}</div></div><h4>Book Item</h4><form onsubmit="submitBooking(event,${i.id})" class="g"><label>Start<input required name="start" type="date"></label><label>End<input required name="end" type="date"></label><label>Type<select name="rentalType"><option>hourly</option><option selected>daily</option><option>weekly</option><option>monthly</option></select></label><label>Message<textarea name="message" placeholder="pickup/delivery request"></textarea></label><p id="bookingError" class="muted" style="color:#cc2f2f;margin:0"></p><button class="btn primary" type="submit">Booking Request</button></form><div class="actions"><button class="btn" onclick="sendMessage(${i.ownerId})">Message</button><button class="btn" onclick="toggleOwnerLike(${i.ownerId})">Like owner</button><button class="btn" onclick="followOwner(${i.ownerId})">Follow owner</button><button class="btn" onclick="followCategory('${i.category}')">Follow category</button></div><h4>Owner</h4><p class="muted"><b>${o?.name||''}</b> • Rating ${o?.rating||'-'} • Verified ${o?.verified?'Yes':'No'}</p><button class="btn" onclick="viewProfile(${o?.id||1})">View profile</button></div></div><h4>Similar items</h4><div class="chips">${similar.map(x=>`<span class="chip">${x.name}</span>`).join('')||'<span class="chip">No similar items</span>'}</div><h4>Items from same owner</h4><div class="chips">${sameOwner.map(x=>`<span class="chip">${x.name}</span>`).join('')||'<span class="chip">No items</span>'}</div>`;
  }
  function renderProfile(){
    const u=state.users.find(x=>x.id===state.selectedProfile)||state.users[0],listings=state.items.filter(i=>i.ownerId===u.id),history=state.bookings.filter(b=>b.customerId===u.id||b.ownerId===u.id);
    $('profile').innerHTML=`<div class="split"><div><h4 style="margin:0">${u.name}</h4><div class="muted">${u.role.toUpperCase()} • ${u.city}</div><p class="muted">${u.bio}</p><div class="chips"><span class="chip">⭐ ${u.rating}</span><span class="chip">Rentals ${u.rentalCount}</span><span class="chip">Reviews ${u.reviewCount}</span><span class="chip">Verified ${u.verified?'Yes':'No'}</span><span class="chip">2FA ${u.twoFa?'Enabled':'Disabled'}</span><span class="chip">Followers ${u.followers}</span><span class="chip">Following ${u.following}</span></div><h4>Security & trust</h4><ul><li>Identity verification: ${u.verified?'Completed':'Pending'}</li><li>Email/phone confirmation: Completed</li><li>User blocking: Enabled</li><li>Fraud score: Low risk</li></ul></div><div><h4>Listings</h4><div class="chips">${listings.map(i=>`<span class="chip">${i.name}</span>`).join('')||'<span class="chip">No listings</span>'}</div><h4>Rental history</h4>${history.map(b=>`<p class="muted">#${b.id}: ${b.start} → ${b.end} <b>${b.status}</b></p>`).join('')||'<p class="muted">No rentals yet</p>'}</div></div>`;
  }
  function renderOwner(){
    const o=state.users.find(u=>u.role==='owner'),listings=state.items.filter(i=>i.ownerId===o.id),bq=state.bookings.filter(b=>b.ownerId===o.id);
    $('owner').innerHTML=`<div class="split"><div><div class="k"><div class="muted">Active listings</div><div class="v">${listings.length}</div></div><div class="k" style="margin-top:8px"><div class="muted">Pending bookings</div><div class="v">${bq.filter(b=>b.status==='requested').length}</div></div><div class="k" style="margin-top:8px"><div class="muted">Monthly income (est.)</div><div class="v">$1240</div></div><h4>Inventory & listings</h4>${listings.map(i=>`<div class="k" style="margin-bottom:8px"><b>${i.name}</b><div class="muted">Calendar: ${i.availability.join(', ')}</div><div class="muted">Pricing h/d/w/m: ${i.pricing.hourly}/${i.pricing.daily}/${i.pricing.weekly}/${i.pricing.monthly}</div><div class="muted">Moderation: media approved, photo checks on</div></div>`).join('')}<h4>Booking queue</h4>${bq.map(b=>`<div class="k" style="margin-bottom:8px"><b>#${b.id} ${state.items.find(i=>i.id===b.itemId)?.name||''}</b><div class="muted">${b.start} → ${b.end} • ${b.rentalType}</div><div class="muted">Deposit: ${b.deposit} • Late fee/day: $${b.lateFee}</div><div class="actions"><button class="btn" onclick="setBooking(${b.id},'confirmed')">Confirm</button><button class="btn" onclick="setBooking(${b.id},'cancelled')">Cancel</button><button class="btn" onclick="setBooking(${b.id},'completed')">Complete</button></div></div>`).join('')}</div><div><h4>Monetization hooks</h4><div class="k">Commission per rental: ${state.monetization.commission}%</div><div class="k" style="margin-top:8px">Promoted listing: $${state.monetization.promoted}/week</div><div class="k" style="margin-top:8px">Owner subscription: $${state.monetization.ownerSub}/month</div><div class="k" style="margin-top:8px">Top placement + ads + premium business tools</div><div class="k" style="margin-top:8px">Insurance per rental: $${state.monetization.insurance}</div></div></div>`;
  }
  function renderAdmin(){
    $('admin').innerHTML=`<div class="split"><div><div class="k"><div class="muted">Users</div><div class="v">${state.users.length}</div></div><div class="k" style="margin-top:8px"><div class="muted">Items</div><div class="v">${state.items.length}</div></div><div class="k" style="margin-top:8px"><div class="muted">Revenue (monthly)</div><div class="v">$4850</div></div><h4>Complaints / moderation</h4>${state.complaints.map(c=>`<div class="k" style="margin-bottom:8px"><b>#${c.id} ${c.subject}</b><div class="muted">Status: ${c.status} • Severity: ${c.severity}</div><div class="actions"><button class="btn">Warn user</button><button class="btn">Ban/Suspend</button><button class="btn">Resolve</button></div></div>`).join('')}</div><div><h4>Trust & safety</h4><ul><li>Identity verification queue and phone/email confirmation checks</li><li>Photo/video moderation hooks and suspicious content flags</li><li>Audit log for moderation actions and booking transitions</li><li>Fraud prevention scoring and account blocking tools</li><li>Analytics: popular categories, booking stats, banners/content controls</li></ul></div></div>`;
  }
  function renderChat(){
    $('chat').innerHTML=state.chat.map(m=>`<p class="muted"><b>${m.from}:</b> ${m.text}</p>`).join('')+`<p class="muted">Spam protection: repeated text throttle + unsafe-link checks enabled.</p>`;
    $('notifications').innerHTML=`<h4 style="margin:0 0 8px">Notifications</h4>`+state.notifications.map(n=>`<div class="k" style="margin-bottom:8px"><div><b>${n.type.toUpperCase()}</b></div><div class="muted">${n.text}</div><div class="muted">${n.ts}</div></div>`).join('');
  }
  function renderSupport(){
    $('supportChat').innerHTML=state.supportChat.map(m=>`<p class="muted"><b>${m.from}:</b> ${m.text}</p>`).join('');
  }
  window.selectItem=id=>{state.selectedItem=id;state.selectedMedia=0;renderDetail();};
  window.selectMedia=i=>{state.selectedMedia=i;renderDetail();};
  window.toggleItemLike=id=>{const it=state.items.find(i=>i.id===id);if(!it)return;if(state.likes.items.has(id)){state.likes.items.delete(id);it.likes--;}else{state.likes.items.add(id);it.likes++;}filterItems();};
  window.addFavorite=id=>{state.notifications.unshift({type:'favorite',text:`Item #${id} added to favorites`,ts:'now'});renderChat();};
  window.toggleOwnerLike=id=>{state.likes.owners.has(id)?state.likes.owners.delete(id):state.likes.owners.add(id);state.notifications.unshift({type:'like',text:'Owner profile like updated',ts:'now'});renderChat();};
  window.followOwner=id=>{state.follows.owners.add(id);state.notifications.unshift({type:'follow',text:'You followed this owner',ts:'now'});renderChat();};
  window.followCategory=c=>{state.follows.categories.add(c);state.notifications.unshift({type:'follow',text:`Subscribed to category: ${c}`,ts:'now'});renderChat();};
  window.sendMessage=id=>{state.chat.push({from:'Customer',text:`Hi ${state.users.find(u=>u.id===id)?.name||''}, need delivery details.`});renderChat();};
  window.sendSupportMessage=()=>{const input=$('supportInput');const text=(input?.value||'').trim();if(!text)return;state.supportChat.push({from:'Customer',text});state.supportChat.push({from:'Support',text:'Thanks! We received your message and will reply soon.'});state.notifications.unshift({type:'support',text:'New message sent to support',ts:'now'});if(input)input.value='';renderSupport();renderChat();};
  window.viewProfile=id=>{state.selectedProfile=id;renderProfile();window.scrollTo({top:$('profilePane').offsetTop-60,behavior:'smooth'});};
  window.submitBooking=(e,itemId)=>{e.preventDefault();const d=new FormData(e.target),start=d.get('start'),end=d.get('end'),rentalType=d.get('rentalType'),msg=d.get('message'),err=$('bookingError');if(!start||!end||new Date(end)<new Date(start)){if(err)err.textContent='Please select valid start and end dates. End date must be after start date.';return;}if(err)err.textContent='';const item=state.items.find(i=>i.id===itemId),b={id:Date.now()+Math.floor(Math.random()*1000),itemId,customerId:1,ownerId:item.ownerId,start,end,rentalType,status:'requested',lateFee:10,deposit:'held'};state.bookings.unshift(b);state.chat.push({from:'Customer',text:msg||'Booking request sent.'});state.notifications.unshift({type:'booking',text:`Booking #${b.id} requested`,ts:'now'});renderOwner();renderProfile();renderChat();e.target.reset();};
  window.setBooking=(id,status)=>{const b=state.bookings.find(x=>x.id===id);if(!b)return;b.status=status;state.notifications.unshift({type:'booking',text:`Booking #${id} status: ${status}`,ts:'now'});renderOwner();renderProfile();renderChat();};
  document.querySelectorAll('.role').forEach(b=>b.onclick=()=>{state.role=b.dataset.role;document.querySelectorAll('.role').forEach(x=>x.classList.toggle('active',x===b));$('ownerPane').classList.toggle('hidden',!(state.role==='owner'||state.role==='admin'));$('adminPane').classList.toggle('hidden',state.role!=='admin');$('filters').classList.toggle('hidden',state.role==='admin');$('customerPane').classList.toggle('hidden',state.role==='admin');$('detailPane').classList.toggle('hidden',state.role==='admin');$('chatPane').classList.toggle('hidden',state.role==='guest');});
  document.querySelectorAll('.quick').forEach(b=>b.onclick=()=>{state.chat.push({from:'System',text:b.dataset.text});renderChat();});
  document.querySelectorAll('.supportQuick').forEach(b=>b.onclick=()=>{state.supportChat.push({from:'Customer',text:b.dataset.text});state.supportChat.push({from:'Support',text:'Request accepted. We are checking and will respond shortly.'});renderSupport();});
  $('supportSend').onclick=()=>window.sendSupportMessage();
  $('supportInput').addEventListener('keydown',e=>{if((e.ctrlKey||e.metaKey)&&e.key==='Enter')window.sendSupportMessage();});
  $('apply').onclick=filterItems;$('reset').onclick=()=>{document.querySelectorAll('#filters input,#filters select').forEach(el=>el.value='');filterItems();};
  initFilters();renderItems(state.items);renderDetail();renderProfile();renderOwner();renderAdmin();renderChat();renderSupport();filterItems();
</script>
</body>
</html>
